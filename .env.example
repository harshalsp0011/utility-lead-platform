# SYSTEM
DEPLOY_ENV=local
APP_NAME=utility-lead-platform
LOG_LEVEL=INFO

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=

# SEARCH
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPER_API_KEY=

# SCRAPING
PROXY_PROVIDER=scraperapi
SCRAPERAPI_KEY=
BRIGHTDATA_KEY=
REQUEST_DELAY_SECONDS=2
MAX_RETRIES=3

# CONTACT ENRICHMENT
ENRICHMENT_PROVIDER=hunter
HUNTER_API_KEY=
APOLLO_API_KEY=

# DATABASE
DATABASE_URL=postgresql://admin:password@localhost:5432/leads

# EMAIL
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
INSTANTLY_API_KEY=
EMAIL_DAILY_LIMIT=50
FOLLOWUP_DAY_1=3
FOLLOWUP_DAY_2=7
FOLLOWUP_DAY_3=14

# ALERTS
SLACK_WEBHOOK_URL=
ALERT_EMAIL=

# SCORING WEIGHTS
SCORE_WEIGHT_RECOVERY=0.40
SCORE_WEIGHT_INDUSTRY=0.25
SCORE_WEIGHT_MULTISITE=0.20
SCORE_WEIGHT_DATA_QUALITY=0.15
HIGH_SCORE_THRESHOLD=70
MEDIUM_SCORE_THRESHOLD=40

# TROY & BANKS
TB_CONTINGENCY_FEE=0.24
TB_SENDER_NAME=
TB_SENDER_TITLE=
TB_PHONE=
